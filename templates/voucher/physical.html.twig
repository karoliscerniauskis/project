<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gift Voucher</title>
</head>
<body style="margin: 0; padding: 0; background: #ffffff; color: #111827; font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; display: flex; align-items: center; justify-content: center; min-height: 100vh;">
    <div style="width: 100%; max-width: 800px; overflow: hidden; border: 2px solid #e2e8f0; border-radius: 24px; background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%); box-shadow: 0 20px 60px rgba(15, 23, 42, 0.15);">
        <div style="padding: 48px 40px; text-align: center;">
            <div style="margin-bottom: 8px;">
                <span style="display: inline-block; padding: 6px 12px; border: 1px solid rgba(15, 23, 42, 0.08); border-radius: 999px; background: rgba(255, 255, 255, 0.9); color: #64748b; font-size: 11px; font-weight: 600; letter-spacing: 0.05em;">
                    VOUCHERA
                </span>
            </div>

            <p style="margin: 20px 0 8px; color: #64748b; font-size: 14px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase;">
                Gift Voucher
            </p>

            <h1 style="margin: 0 0 32px; color: #020617; font-size: 36px; line-height: 1.2; font-weight: 700; letter-spacing: -0.02em;">
                {{ providerName }}
            </h1>

            <div style="margin: 32px 0;">
                <div style="font-size: 56px; font-weight: 700; color: #020617; margin-bottom: 24px; line-height: 1;">
                    {{ valueText }}
                </div>
                <div style="display: inline-block; font-family: 'Courier New', monospace; font-size: 28px; background: #f8fafc; padding: 18px 32px; border-radius: 12px; border: 2px solid #e2e8f0; letter-spacing: 6px; color: #020617; margin: 0 auto;">
                    {{ code }}
                </div>
            </div>

            <div style="margin-top: 32px; color: #64748b; font-size: 15px;">
                Valid until: <strong style="color: #475569;">{{ expirationText }}</strong>
            </div>
        </div>

        <div style="border-top: 1px solid #e2e8f0; padding: 20px 40px; background: rgba(248, 250, 252, 0.5); text-align: center;">
            <p style="margin: 0; color: #94a3b8; font-size: 12px; line-height: 1.6;">
                Secure. Simple. Transferable.
            </p>
        </div>
    </div>
</body>
</html>
