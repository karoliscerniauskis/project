<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ subject }}</title>
</head>
<body style="margin: 0; padding: 0; background: #f5f5f7; color: #111827; font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;">
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="min-width: 320px; background: #f5f5f7;">
    <tr>
        <td align="center" style="padding: 40px 16px;">
            <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width: 640px;">
                <tr>
                    <td style="padding: 0 0 20px;">
                        <div style="display: inline-block; padding: 8px 14px; border: 1px solid rgba(15, 23, 42, 0.08); border-radius: 999px; background: rgba(255, 255, 255, 0.72); color: #475569; font-size: 13px; font-weight: 600;">
                            🎁 Vouchera
                        </div>
                    </td>
                </tr>

                <tr>
                    <td style="overflow: hidden; border: 1px solid rgba(255, 255, 255, 0.72); border-radius: 32px; background: rgba(255, 255, 255, 0.86); box-shadow: 0 24px 80px rgba(15, 23, 42, 0.10);">
                        <table role="presentation" width="100%" cellspacing="0" cellpadding="0">
                            <tr>
                                <td style="padding: 36px 32px 32px;">
                                    <p style="margin: 0 0 14px; color: #64748b; font-size: 13px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase;">
                                        Notification
                                    </p>

                                    <h1 style="margin: 0; color: #020617; font-size: 30px; line-height: 1.12; font-weight: 700; letter-spacing: -0.04em;">
                                        {{ subject }}
                                    </h1>

                                    <div style="margin-top: 22px; color: #475569; font-size: 16px; line-height: 1.75;">
                                        {{ message|nl2br }}
                                    </div>

                                    {% if actionUrl is defined and actionUrl %}
                                        <table role="presentation" cellspacing="0" cellpadding="0" style="margin-top: 30px;">
                                            <tr>
                                                <td>
                                                    <a href="{{ actionUrl }}" style="display: inline-block; border-radius: 999px; background: #020617; padding: 14px 22px; color: #ffffff; font-size: 14px; font-weight: 700; text-decoration: none;">
                                                        {{ actionLabel|default('Open') }}
                                                    </a>
                                                </td>
                                            </tr>
                                        </table>
                                    {% endif %}
                                </td>
                            </tr>

                            <tr>
                                <td style="border-top: 1px solid #e2e8f0; padding: 22px 32px; background: rgba(248, 250, 252, 0.72);">
                                    <p style="margin: 0; color: #64748b; font-size: 13px; line-height: 1.6;">
                                        This email was sent automatically. Please do not reply to this message.
                                    </p>
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>

                <tr>
                    <td align="center" style="padding: 22px 12px 0;">
                        <p style="margin: 0; color: #94a3b8; font-size: 12px;">
                            Secure. Simple. Transferable.
                        </p>
                    </td>
                </tr>
            </table>
        </td>
    </tr>
</table>
</body>
</html>
